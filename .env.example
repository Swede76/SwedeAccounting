# Environment Configuration Template

# Flask Configuration
FLASK_ENV=production
FLASK_APP=app/main.py
DEBUG=False

# Security
SECRET_KEY=change-me-to-a-random-secret-key-in-production
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret-key

# Database
# For local development:
# DATABASE_URL=postgresql://user:password@localhost:5432/swedeaccounting_dev
#
# For production (Heroku, Railway, etc):
# DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:password@localhost:5432/swedeaccounting

# Server
PORT=5000
HOST=0.0.0.0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Email (optional for future features)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# Logging
LOG_LEVEL=INFO
